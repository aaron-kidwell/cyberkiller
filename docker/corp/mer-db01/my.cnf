[mysqld]
# Intentionally permissive: secure_file_priv=/ lets LOAD_FILE and SELECT ...
# INTO OUTFILE read/write anywhere under / the mysql user can reach - the
# classic "MySQL FILE privilege -> RCE" path. (An empty value is parsed as NULL,
# which DISABLES FILE ops, so we use "/" instead.)
secure_file_priv = /
local_infile = 1
