# CyberKiller configuration. Copy to .env (or let ./deploy.sh generate one).
# ./deploy.sh fills the secrets + host IP automatically on first run.

# Database + auth secrets (generate: openssl rand -hex N)
POSTGRES_PASSWORD=change-me-strong-random
JWT_SECRET=change-me-64-hex-openssl-rand-hex-32

# Admin panel login. Reach the panel via SSH tunnel to 127.0.0.1:3001.
ADMIN_USER=admin
ADMIN_PASS=change-me-strong-password

# Where players reach the API + hub. Use this host's IP for a LAN/VPS deploy,
# or your https URL if you put it behind a domain + TLS.
API_URL=http://your-host:8080
CORS_ORIGINS=http://your-host:3000,http://localhost:3000

# Player signup
SIGNUP_OPEN=true
SIGNUP_INVITE_CODE=change-me

# Ship the bundled MERIDIAN example scenario (10-box Linux breach chain)
CORP_ORCHESTRATION=true
MAX_ACTIVE_HILLS=5

# Arena network (deploy.sh auto-fills these on first run):
#   lan    = targets attach to your physical LAN via ipvlan; each box gets a real
#            LAN IP (ARENA_IP_PREFIX.200-223) reachable from any machine, no routes.
#   bridge = private 10.66.20.0/24, reachable from the host only (single host/cloud).
ARENA_MODE=lan
ARENA_PARENT=eth0
ARENA_SUBNET=192.168.1.0/24
ARENA_GATEWAY=192.168.1.1
ARENA_IP_PREFIX=192.168.1
ARENA_BOX_BASE=200

# Port bindings (admin stays on localhost on purpose)
API_BIND=8080
WEB_BIND=3000
ADMIN_BIND=127.0.0.1:3001
